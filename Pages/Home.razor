@page "/"
@using PWA.Models
@inject PWA.Services.CitasSyncService CitasService
@inject PWA.Services.SaludSyncService SaludService
@inject PWA.Services.TratamientosSyncService TratamientosService

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Salud a Tiempo</h1>
        <p class="page-subtitle">Organiza tus citas, tratamientos y seguimiento básico de salud en un solo lugar.</p>
    </div>

    @if (proximaCita is not null && proximaCita.FechaHora <= DateTime.Now.AddDays(1))
    {
        <div class="custom-alert custom-alert-warning">
            <strong>Recordatorio:</strong> tienes una cita próxima de <strong>@proximaCita.TipoConsulta</strong>
            el @proximaCita.FechaHora.ToString("dd/MM/yyyy HH:mm") en @proximaCita.Lugar.
        </div>
    }

    @if (tratamientosActivosLista.Any())
    {
        <div class="custom-alert custom-alert-info">
            <strong>Recordatorio:</strong> tienes @tratamientosActivosLista.Count tratamiento(s) activo(s) registrados.
        </div>
    }

    <div class="dashboard-grid">
        <div class="dashboard-card">
            <h3>Total de citas</h3>
            <div class="dashboard-value">@totalCitas</div>
        </div>

        <div class="dashboard-card">
            <h3>Tratamientos activos</h3>
            <div class="dashboard-value">@tratamientosActivos</div>
        </div>

        <div class="dashboard-card">
            <h3>Último peso registrado</h3>
            <div class="dashboard-value">
                @(ultimoRegistro is null ? "—" : $"{ultimoRegistro.Peso} kg")
            </div>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="section-card">
            <h2 class="section-title">Próxima cita</h2>

            @if (proximaCita is null)
            {
                <p class="dashboard-text">No hay citas próximas.</p>
            }
            else
            {
                <p class="record-title">@proximaCita.TipoConsulta</p>
                <p class="record-text"><strong>Fecha:</strong> @proximaCita.FechaHora.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="record-text"><strong>Lugar:</strong> @proximaCita.Lugar</p>
                <p class="record-text"><strong>Estado:</strong> @proximaCita.SyncStatus</p>
            }
        </div>

        <div class="section-card">
            <h2 class="section-title">Último registro de salud</h2>

            @if (ultimoRegistro is null)
            {
                <p class="dashboard-text">No hay registros de salud.</p>
            }
            else
            {
                <p class="record-text"><strong>Fecha:</strong> @ultimoRegistro.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="record-text"><strong>Peso:</strong> @ultimoRegistro.Peso kg</p>
                <p class="record-text"><strong>Presión:</strong> @ultimoRegistro.PresionSistolica/@ultimoRegistro.PresionDiastolica mmHg</p>
                <p class="record-text"><strong>Estado:</strong> @ultimoRegistro.SyncStatus</p>
            }
        </div>
    </div>

    @if (tratamientosActivosLista.Any())
    {
        <div class="list-card">
            <h2 class="section-title">Tratamientos activos</h2>

            <ul class="record-list">
                @foreach (var tratamiento in tratamientosActivosLista)
                {
                    <li class="record-item">
                        <div class="badge-status badge-active">Activo</div>
                        <p class="record-title">@tratamiento.Nombre</p>
                        <p class="record-text"><strong>Dosis:</strong> @tratamiento.Dosis</p>
                        <p class="record-text"><strong>Frecuencia:</strong> @tratamiento.Frecuencia</p>
                        <p class="record-text"><strong>Inicio:</strong> @tratamiento.FechaInicio.ToString("dd/MM/yyyy")</p>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="quick-actions">
        <a class="btn btn-primary" href="/citas">Ir a citas</a>
        <a class="btn btn-success" href="/seguimiento">Ir a seguimiento</a>
        <a class="btn btn-warning" href="/tratamientos">Ir a tratamientos</a>
    </div>
</div>

@code {
    private List<CitaMedica> citas = new();
    private List<RegistroSalud> registros = new();
    private List<Tratamiento> tratamientos = new();
    private List<Tratamiento> tratamientosActivosLista = new();

    private int totalCitas;
    private int tratamientosActivos;
    private CitaMedica? proximaCita;
    private RegistroSalud? ultimoRegistro;

    protected override async Task OnInitializedAsync()
    {
        citas = await CitasService.ObtenerTodasAsync();
        registros = await SaludService.ObtenerTodosAsync();

        tratamientos = await TratamientosService.ObtenerTodosAsync();

        totalCitas = citas.Count;

        var ahora = DateTime.Now;

        proximaCita = citas
            .Where(c => c.FechaHora >= ahora && !c.IsDeleted)
            .OrderBy(c => c.FechaHora)
            .FirstOrDefault();

        ultimoRegistro = registros
            .Where(r => !r.IsDeleted)
            .OrderByDescending(r => r.FechaRegistro)
            .FirstOrDefault();

        tratamientosActivosLista = tratamientos
            .Where(t => t.Activo)
            .ToList();

        tratamientosActivos = tratamientosActivosLista.Count;
    }
}